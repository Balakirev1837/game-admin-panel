# Game Admin Panel Environment Variables
# Copy this file to .env and adjust values before running docker-compose up.

# Port the admin panel listens on (host-side mapping).
# The container always exposes port 3000 internally.
PORT=3000

# Docker host connection string. Leave empty to use the default
# Unix socket (/var/run/docker.sock), which is mounted by docker-compose.
DOCKER_HOST=

# Default RCON password for Icarus game servers.
ICARUS_RCON_PASSWORD=dateniteroolz

# Path to the Icarus server config file inside the container.
# The ./config host directory is mounted at /config in the container.
ICARUS_CONFIG_PATH=./config/ServerSettings.ini
